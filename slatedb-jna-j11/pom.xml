<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.slatedb.flink.poc</groupId>
  <artifactId>slatedb-jna-j11</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>

  <!--
    Proves the SlateDB "Java 22 floor" is a PACKAGING choice, not a SlateDB limit.

    The official io.slatedb:slatedb-uniffi artifact (used by the slatedb-verify module) is
    generated by uniffi-bindgen-java (IronCoreLabs), which emits java.lang.foreign / FFM code and
    therefore REQUIRES JDK 22+ (class version 66). That is the only reason SlateDB "needs Java 22".

    The SAME native library also has a Mozilla-standard Kotlin/JNA UniFFI front-end. JNA runs on
    Java 8+. This module checks in that regenerated-and-patched Kotlin binding (package
    uniffi.slatedb.*, distinct from the FFM binding's io.slatedb.uniffi.*), compiles it to JVM 11
    bytecode, and drives REAL SlateDB ops from plain Java on JDK 11 — put/get, MEMTABLE flush, and
    a detached checkpoint (the async-heavy op Flink needs for exactly-once).

    == How the checked-in binding was produced (reproducible; see README §17 / journal Phase 10) ==
      1. worktree at the v0.14.1 release tag (so the binding matches the PUBLISHED native lib exactly;
         clone HEAD had drifted: it added admin_run_gc_once, absent from the 0.14.1 .dylib).
      2. uniffi-bindgen 0.31.1 (matching Cargo.lock): generate, language=kotlin, from the library.
      3. patched a uniffi-0.31 codegen bug: error variants declare a `message` constructor property
         which collides with Throwable.message, so it does not compile on ANY kotlinc. Fix: make it an
         `override val` and drop the redundant getter (7 sites). The concrete "fork maintenance tax".

    == Runtime native library ==
      This module does NOT depend on the FFM jar. It reuses the PUBLISHED native lib that the other
      modules already extract from the Maven artifact. Put libslatedb_uniffi.dylib (or .so/.dll) on
      -Djna.library.path (see README run steps). No Rust toolchain needed to RUN this module.

    Runs on JDK 11, 17, and 25 with no enable-native-access / add-opens flags (those are FFM-only).
  -->

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>11</maven.compiler.release>
    <kotlin.version>1.9.24</kotlin.version>
    <kotlin.compiler.jvmTarget>11</kotlin.compiler.jvmTarget>
    <!-- Versions bundled with kotlinc 1.9.24; JNA matches the official binding's declared dep. -->
    <coroutines.version>1.7.3</coroutines.version>
    <jna.version>5.18.1</jna.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.jetbrains.kotlin</groupId>
      <artifactId>kotlin-stdlib</artifactId>
      <version>${kotlin.version}</version>
    </dependency>
    <dependency>
      <groupId>org.jetbrains.kotlinx</groupId>
      <artifactId>kotlinx-coroutines-core-jvm</artifactId>
      <version>${coroutines.version}</version>
    </dependency>
    <dependency>
      <groupId>net.java.dev.jna</groupId>
      <artifactId>jna</artifactId>
      <version>${jna.version}</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <!--
        Kotlin compiler: compiles the checked-in binding (src/main/kotlin/uniffi/slatedb/slatedb.kt)
        and the blocking bridge (io/slatedb/flink/poc/SlateBridge.kt) to JVM 11 bytecode, BEFORE
        javac so the Java main can see the generated classes.
      -->
      <plugin>
        <groupId>org.jetbrains.kotlin</groupId>
        <artifactId>kotlin-maven-plugin</artifactId>
        <version>${kotlin.version}</version>
        <configuration>
          <jvmTarget>${kotlin.compiler.jvmTarget}</jvmTarget>
        </configuration>
        <executions>
          <execution>
            <id>compile</id>
            <phase>process-sources</phase>
            <goals><goal>compile</goal></goals>
            <configuration>
              <sourceDirs>
                <sourceDir>${project.basedir}/src/main/kotlin</sourceDir>
              </sourceDirs>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- javac: compiles the plain-Java main against the Kotlin output. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <executions>
          <execution>
            <id>default-compile</id>
            <phase>compile</phase>
            <goals><goal>compile</goal></goals>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <configuration>
          <mainClass>io.slatedb.flink.poc.SlateDbJnaJ11Main</mainClass>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
